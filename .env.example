# Redis Configuration
REDIS_BROKER_URI=redis://localhost:6379/0
REDIS_LOCK_URI=redis://localhost:6379/1
REDIS_DEDUP_URI=redis://localhost:6379/2
REDIS_STATE_URI=redis://localhost:6379/3

# Jira Configuration
JIRA_INSTANCE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECT_KEY=YOUR_PROJECT  # Can be any Jira project key
JIRA_USER_EMAIL=bot@your-org.com

# Webhook Security
WEBHOOK_SECRET=your-webhook-hmac-secret-here

# Claude AI / Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Application Settings
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=false

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE=UTC
CELERY_MAX_RETRIES=3

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# LangFuse (optional - for observability)
LANGFUSE_PUBLIC_KEY=your-public-key
LANGFUSE_SECRET_KEY=your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# GitHub (for repository analysis)
GITHUB_TOKEN=your-github-token-here
GITHUB_API_URL=https://api.github.com

# Monitoring
PROMETHEUS_ENABLED=true
METRICS_PORT=9090

# Feature Flags
ENABLE_FEEDBACK_LOOPS=true
ENABLE_QUALITY_VALIDATION=true
ENABLE_CONSTITUTION_CHECKS=true
