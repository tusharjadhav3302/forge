{
  "github": {
    "transport": "http",
    "url": "https://api.githubcopilot.com/mcp",
    "headers": {
      "Authorization": "Bearer ${GITHUB_TOKEN}"
    }
  },
  "gitmcp": {
    "transport": "streamable_http",
    "url": "https://gitmcp.io/{owner}/{repo}"
  },
  "atlassian": {
    "transport": "sse",
    "url": "http://127.0.0.1:8080/sse"
  },
  "context7": {
    "transport": "stdio",
    "command": "npx",
    "args": ["-y", "@upstash/context7-mcp"]
  }
}
